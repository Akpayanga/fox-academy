# API Configuration
# Backend API Base URL
# For local dev with Vite proxy, keep this as /api/v1.
# For deployed frontend (e.g. Vercel), set this to your full backend URL,
# e.g. https://fox-academy.onrender.com/api/v1.
# If omitted in production, the app now falls back to the Render URL above.
VITE_API_BASE_URL=/api/v1

# Environment
VITE_ENV=development

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname
